# R90 Navigator — Environment Variables
# Copy this file to .env and fill in the values

# nick_brain backend URL (Railway / local)
EXPO_PUBLIC_NICK_BRAIN_API_URL=https://app-nick-production.up.railway.app

# PostHog analytics
EXPO_PUBLIC_POSTHOG_KEY=phc_...  # Get from posthog.com → project settings

# Supabase (anon key is public-safe, used client-side with RLS)
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co  # Supabase dashboard → Settings → API
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJ...  # Supabase dashboard → Settings → API → anon/public key

# Google Calendar OAuth (platform-specific client IDs)
EXPO_PUBLIC_GOOGLE_CALENDAR_IOS_CLIENT_ID=xxx.apps.googleusercontent.com  # Google Cloud Console → iOS client
EXPO_PUBLIC_GOOGLE_CALENDAR_ANDROID_CLIENT_ID=xxx.apps.googleusercontent.com  # Google Cloud Console → Android client
